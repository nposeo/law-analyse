---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="uk">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title} | Law Analyse</title>
  <meta name="description" content="Аналіз законів України з AI">
</head>
<body class="bg-gray-50 min-h-screen">
  <header class="bg-white shadow-sm">
    <div class="max-w-7xl mx-auto px-4 py-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between">
        <a href="/" class="text-2xl font-bold text-blue-600">Law Analyse</a>
        <nav class="text-sm text-gray-600">
          AI-аналіз законів України
        </nav>
      </div>
    </div>
  </header>

  <main class="max-w-7xl mx-auto px-4 py-8 sm:px-6 lg:px-8">
    <slot />
  </main>

  <footer class="bg-white border-t mt-12">
    <div class="max-w-7xl mx-auto px-4 py-6 sm:px-6 lg:px-8">
      <p class="text-center text-sm text-gray-500">
        Law Analyse MVP © 2026 | Powered by OpenAI GPT-4o
      </p>
    </div>
  </footer>
</body>
</html>
